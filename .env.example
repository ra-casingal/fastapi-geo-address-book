# ============================================================
# Environment variables for Address Book API
# ============================================================
# Copy this file to .env and fill in the values appropriate
# for your environment.  Never commit .env to version control.
# ============================================================

# Human-readable API name shown in the OpenAPI /docs UI.
PROJECT_NAME="Address Book API"

# Semantic version string returned by the health-check endpoint.
VERSION="0.1.0"

# SQLAlchemy database connection string.
#
# SQLite (default, suitable for local development and testing):
#   DATABASE_URL="sqlite:///./address_book.db"
#
# PostgreSQL (recommended for staging / production):
#   DATABASE_URL="postgresql+psycopg2://user:password@localhost:5432/address_book"
#
# MySQL / MariaDB:
#   DATABASE_URL="mysql+pymysql://user:password@localhost:3306/address_book"
DATABASE_URL="sqlite:///./address_book.db"
